{
  "name": "refarch-webcomponent",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.11 <25"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "npm run pre-build && vue-tsc --build --noCheck && vite build && npm run post-build",
    "pre-build": "openapi-generator-cli generate",
    "post-build": "node ./processes/post-build.js && cyclonedx-npm --omit dev --omit optional --output-reproducible -o dist/application.cdx.json",
    "preview": "vite preview",
    "lint": "npm run pre-build && prettier . --check --cache && eslint . --cache --concurrency auto && vue-tsc --build --noEmit",
    "fix": "prettier . --write --cache && eslint . --fix --cache --concurrency auto"
  },
  "dependencies": {
    "@muenchen/muc-patternlab-vue": "8.1.0",
    "@vueuse/core": "14.2.1",
    "vue": "3.5.32"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@eslint/js": "10.0.1",
    "@muenchen/prettier-codeformat": "1.0.2",
    "@openapitools/openapi-generator-cli": "2.31.1",
    "@tsconfig/node-lts": "24.0.0",
    "@types/node": "24.11.2",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.2.1",
    "eslint-plugin-vue": "10.9.0",
    "jsdom": "29.0.2",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "vite": "8.0.8",
    "vite-plugin-vue-devtools": "8.1.1",
    "vitest": "4.1.4",
    "vue-tsc": "3.2.6"
  }
}
